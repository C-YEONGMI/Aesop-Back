NODE_ENV=development
PORT=4000
# Atlas SRV example
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/aesop?retryWrites=true&w=majority

# Atlas standard example
# MONGODB_URI=mongodb://<username>:<password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/aesop?replicaSet=<replica-set>&authSource=admin&tls=true

# Local MongoDB example
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=aesop
MONGODB_AUTH_SOURCE=
MONGODB_FAMILY=4
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
# Set to false to watch the scraper browser while syncing directly to MongoDB
SCRAPER_HEADLESS=true
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_NAME=aesop_refresh_token
COOKIE_DOMAIN=
